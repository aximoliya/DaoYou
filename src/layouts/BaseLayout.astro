---
import '../styles/main.css';

interface Props {
  title: string;
  page?: string;
  current?: string;
}

const { title, page = '', current = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN" data-page={page} data-current={current}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
</head>
<body>
  <slot />
  <script>
    import { initDaoyouApp } from '../modules/main.ts';
    initDaoyouApp();
  </script>
</body>
</html>