---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/NavBar.astro';
import BackToTop from '../components/BackToTop.astro';
import GlobalSearch from '../components/GlobalSearch.astro';
import { homeNavItems } from '../lib/navItems';
---

<BaseLayout title="道友请留步 · 攻略总览" page="hub">
  <NavBar currentPage="/" navItems={homeNavItems} />

  <main>
    <!-- Hero 区 -->
    <div class="hub-hero">
      <h1>道友请留步 · 攻略站</h1>
      <p>覆盖神仙、天书、星姬、幻仙、宠物、灵武、元神、法宝、装备、多选箱等全系统开箱路线</p>
      <p style="color:var(--text-muted);font-size:var(--text-sm);margin-top:8px;">来源：笑语@TapTap · 最后更新 2026-05-12</p>
    </div>

    <!-- 全局搜索 -->
    <GlobalSearch />

    <!-- 统计概览条 -->
    <div class="hub-stats">
      <div class="stat-item">
        <span class="stat-num">17</span>
        <span class="stat-label">攻略页面</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">3</span>
        <span class="stat-label">系统分类</span>
      </div>
      <div class="stat-item">
        <span class="stat-num">10</span>
        <span class="stat-label">开箱子系统</span>
      </div>
    </div>

    <!-- 三大分类横向排列 -->
    <section>
      <div class="hub-row">
        <a href={`${import.meta.env.BASE_URL}/kaixiang/`} class="hub-card hub-card-category">
          <span class="icon">📦</span>
          <span class="label">开箱攻略</span>
          <span class="desc">神仙、天书、星姬、幻仙、宠物、灵武、元神、法宝、装备、道具多选箱 — 10 大子系统开箱路线</span>
        </a>
        <a href={`${import.meta.env.BASE_URL}/richang/`} class="hub-card hub-card-category">
          <span class="icon">🛒</span>
          <span class="label">日常运营</span>
          <span class="desc">商店购买优先级与日常运营指南</span>
        </a>
        <a href={`${import.meta.env.BASE_URL}/yangcheng/`} class="hub-card hub-card-category">
          <span class="icon">🏛️</span>
          <span class="label">养成系统</span>
          <span class="desc">神藏系统节点升级路线与战力实测</span>
        </a>
      </div>
    </section>

    <div class="hub-footer">
      道友攻略站 · 持续更新中 · 攻略来源：笑语@TapTap
    </div>
  </main>

  <BackToTop />
</BaseLayout>