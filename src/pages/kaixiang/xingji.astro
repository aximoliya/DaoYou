---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavBar from '../../components/NavBar.astro';
import TOCPanel from '../../components/TOCPanel.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import BackToTop from '../../components/BackToTop.astro';

import { kaixiangNavItems } from '../../data/navItems';
import PageNav from '../../components/PageNav.astro';
import TimeBadge from '../../components/TimeBadge.astro';

const navItems = kaixiangNavItems;
---

<BaseLayout title="三、星姬 · 道友攻略" page="kaixiang" current="xingji">
  <NavBar currentPage="/kaixiang/xingji/" navItems={navItems} />
  
  <main>
    <Breadcrumb items={[
      { href: '../../', label: '攻略总览' },
      { href: '../', label: '开箱攻略' },
      { label: '三、星姬' }
    ]} />
            <TimeBadge date="2026-05" version="曦幻二版本" />


    <section id="xingji">
      <h2><span class="icon">⭐</span>三、星姬</h2>
      <div class="info">💰 白嫖可在主题活动用2张30额度（或1张30+两个6元）换10碎片补升星缺口，不补会卡3星。牛鹿平均升需4张30额度。</div>

      <h3><span class="badge badge-xh">曦幻</span>与<span class="badge badge-ll">琉璃</span> 星姬</h3>

      <div class="card" data-tiers="jx ll xh">
        <div class="card-title">(1) 没有犴鼠 或 犴鼠≤2星</div>
        <ul class="route" data-tiers="jx ll xh">
          <li><b>曦幻箱</b>：鼠星高先开1牛，否则先开1鹿 → 1鹿1牛 → 鹿牛以3/5/7星为节点平均升星，优先鹿</li>
          <li><b>琉璃4选箱</b>：1鼠（上不了阵就0鼠后0犴）→ 0犴 → 一直升鼠</li>
          <li class="sub">1鼠与鹿可共同上阵，不必在意都属月。升鼠不浪费碎片在犴上方便后续传灵</li>
          <li><b>琉璃2选箱</b>：开完图鉴后一直升燕；蛇比燕高2星就升蛇</li>
        </ul>
      </div>

      <div class="card" data-tiers="jx ll xh">
        <div class="card-title">(2) 有≥3星鼠</div>
        <ul class="route" data-tiers="jx ll xh">
          <li><b>曦幻箱</b>：一直单升牛到5星（3星后可开鹿图鉴），再升鹿</li>
          <li><b>琉璃4选箱</b>：一直单升鼠，直到被鹿换下阵</li>
        </ul>
      </div>

      <div class="card" data-tiers="jx ll xh">
        <div class="card-title">(3) 有≥3星犴</div>
        <ul class="route" data-tiers="jx ll xh">
          <li><b>曦幻箱</b>：一直单升鹿到5星（3星后可开牛图鉴），再升牛</li>
          <li><b>琉璃4选箱</b>：一直单升犴，直到被牛换下阵</li>
        </ul>
      </div>

      <h3>星级替换</h3>

      <h4>曦幻星姬·牛鹿 → 琉璃星姬·犴鼠</h4>
      <table data-tiers="ll xh">
        <tr><th>牛/鹿星级</th><th>上阵-单挑（真实强度）</th><th>上阵-实战搭配</th></tr>
        <tr><td>0星</td><td>换 3~4星蛇/燕，换不了1星犴/鼠</td><td>换不了1星犴/鼠</td></tr>
        <tr><td>1星</td><td>换 4~5星犴/鼠</td><td>换 5~7星犴/鼠</td></tr>
        <tr><td>2星</td><td>换 5~6星犴/鼠</td><td>换 6~7星犴/鼠</td></tr>
        <tr><td>3星</td><td>换 7星犴/鼠</td><td>—</td></tr>
      </table>
      <div class="info" style="margin-top:4px;">🔗 传灵排序（技能孔）：5鼠 ＞ 7燕 ＞ 7犴 ＞ 4鼠 ＞ 3鼠 ＞ 6燕 ＞ 6犴 ＞ 5燕 ＞ 5犴 ＞ 2鼠 ≈ 7蛇 ＞ 6蛇 ＞ 1鼠 ＞ 4燕 ＞ 4犴 ＞ 3燕 ＞ 3犴 ＞ 5蛇 ＞ 2燕 ＞ 2犴 ＞ 4蛇 ＞ 1燕 ＞ 1犴 ＞ 3蛇 ＞ 1蛇 ＞ 0鼠 ＞ 0燕 ＞ 0犴 ＞ 0蛇</div>

      <h4>琉璃星姬·犴鼠 → 金霄星姬·猪/貉+蛇/燕</h4>
      <table data-tiers="jx ll">
        <tr><th>犴/鼠星级</th><th>上阵-单挑</th><th>上阵-搭配</th></tr>
        <tr><td>0星</td><td>换 1~2星猪/貉</td><td>换 1~2星猪/貉</td></tr>
        <tr><td>1星</td><td>换 3~4星蛇/燕</td><td>换 4星蛇/燕</td></tr>
        <tr><td>2星</td><td>换 4星蛇/燕</td><td>换 4~5星蛇/燕</td></tr>
        <tr><td>3星</td><td>换 6星蛇/燕</td><td>换 6~7星蛇/燕</td></tr>
        <tr><td>4星</td><td>换 6~7星蛇/燕</td><td>换 7星蛇/燕</td></tr>
      </table>

      <h3><span class="badge badge-jx">金霄</span>及以下</h3>
      <p>开完图鉴后单升，随便单升哪个。如果箱子里还有九天星魂、星陨石之类的高级材料，开完图鉴后只选材料。</p>
    </section>
  

    <TOCPanel />

  <PageNav currentPath="/kaixiang/xingji/" navItems={kaixiangNavItems} />
</main>


  <BackToTop />
</BaseLayout>