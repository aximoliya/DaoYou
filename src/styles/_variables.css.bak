/* ============================================
   道友攻略站 · 设计系统 v3 (CSS Variables)
   ============================================ */

:root {
  /* 背景层次 */
  --bg:             #080c14;
  --bg-raised:      #0e1420;
  --surface:        #111827;
  --surface-hover:  #182032;
  --surface-active: #1c2640;

  /* 边框 */
  --border:         #1e2d45;
  --border-light:   #263550;

  /* 文字 */
  --text:           #dce4f0;
  --text-secondary: #8899b4;
  --text-muted:     #556680;

  /* 强调色 */
  --accent:         #e8b44f;
  --accent-glow:    rgba(232, 180, 79, 0.15);
  --accent-strong:  #f0c060;

  /* 功能色 */
  --success:        #4fc47f;
  --warning:        #e8b44f;
  --danger:         #f06060;
  --danger-bg:      rgba(240, 96, 96, 0.08);
  --info-bg:        rgba(232, 180, 79, 0.08);

  /* 品质色 */
  --xh:             #f0c060;
  --xh-bg:          linear-gradient(135deg, #f0c060, #d4892a);
  --ll:             #b88cf0;
  --ll-bg:          linear-gradient(135deg, #b88cf0, #7c3aed);
  --jx:             #f0883c;
  --jx-bg:          linear-gradient(135deg, #f0883c, #d85a10);
  --ct:             #f06060;
  --ct-bg:          linear-gradient(135deg, #f06060, #cc2525);
  --zx:             #7c8cf0;
  --zx-bg:          linear-gradient(135deg, #7c8cf0, #5046e0);
  --qy:             #30c8e8;
  --qy-bg:          linear-gradient(135deg, #30c8e8, #1088a0);
  --hc:             #e870a0;
  --hc-bg:          linear-gradient(135deg, #e870a0, #c82868);

  /* 布局 */
  --nav-width:      250px;
  --content-max:    860px;
  --radius-sm:      6px;
  --radius-md:      10px;
  --radius-lg:      14px;

  /* 阴影 */
  --shadow-sm:      0 1px 2px rgba(0,0,0,0.3);
  --shadow-md:      0 4px 16px rgba(0,0,0,0.4);
  --shadow-glow:    0 0 20px var(--accent-glow);

  /* 过渡 */
  --ease-out:       cubic-bezier(0.16, 1, 0.3, 1);
  --ease-spring:    cubic-bezier(0.34, 1.56, 0.64, 1);
  --duration-fast:  150ms;
  --duration-normal:250ms;

  /* 兼容旧版变量 */
  --gold: var(--accent-strong);
  --purple: var(--ll);
  --orange: var(--jx);
  --red: var(--danger);
  --indigo: var(--zx);
  --cyan: var(--qy);
  --pink: var(--hc);
  --green: var(--success);
}

/* 亮色主题 */
[data-theme="light"] {
  --bg:             #f4f5f8;
  --bg-raised:      #ffffff;
  --surface:        #ffffff;
  --surface-hover:  #f0f2f5;
  --surface-active: #e8ecf2;
  --border:         #e0e4ec;
  --border-light:   #eef0f4;
  --text:           #1a2235;
  --text-secondary: #556680;
  --text-muted:     #8899b4;
  --accent:         #c07820;
  --accent-glow:    rgba(192, 120, 32, 0.1);
  --accent-strong:  #a06010;
  --info-bg:        rgba(192, 120, 32, 0.06);
  --danger-bg:      rgba(220, 50, 50, 0.06);
  --shadow-sm:      0 1px 3px rgba(0,0,0,0.06);
  --shadow-md:      0 4px 20px rgba(0,0,0,0.08);
  --shadow-glow:    0 0 20px rgba(192, 120, 32, 0.08);
}