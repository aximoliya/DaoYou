/* ============================================
   道友攻略站 · 基础样式 v3
   ============================================ */
@import './_variables.css';

/* ===================== 基础重置 ===================== */
*, *::before, *::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
  scroll-padding-top: 24px;
}

body {
  background: var(--bg);
  color: var(--text);
  font-family: "PingFang SC", "Microsoft YaHei", "Noto Sans SC", system-ui, sans-serif;
  font-size: 15px;
  line-height: 1.75;
  display: flex;
  min-height: 100vh;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  transition: background var(--duration-normal) var(--ease-out),
              color var(--duration-normal) var(--ease-out);
}

a {
  color: var(--accent);
  text-decoration: none;
  transition: color var(--duration-fast);
}
a:hover { color: var(--accent-strong); }

:focus-visible {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    transition-duration: 0.01ms !important;
  }
  html { scroll-behavior: auto; }
}

.sr-only {
  position: absolute;
  width: 1px; height: 1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border: 0;
}

/* ===================== 侧边栏导航 ===================== */
nav {
  width: var(--nav-width);
  background: var(--bg-raised);
  border-right: 1px solid var(--border);
  position: fixed;
  top: 0; left: 0; bottom: 0;
  overflow-y: auto;
  padding: 24px 0;
  z-index: 100;
  display: flex;
  flex-direction: column;
}

nav::-webkit-scrollbar { width: 4px; }
nav::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
nav::-webkit-scrollbar-track { background: transparent; }

.nav-brand {
  padding: 0 20px 20px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 8px;
  text-decoration: none;
  display: block;
}

.nav-brand h1, nav h1 {
  font-size: 17px;
  font-weight: 800;
  background: linear-gradient(135deg, var(--accent-strong), var(--accent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  letter-spacing: 1px;
  text-align: center;
  padding: 0;
  border-bottom: none;
  margin-bottom: 0;
}

nav h1 {
  padding: 0 20px 16px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 8px;
}

nav h1 a { color: inherit; text-decoration: none; }

.nav-group-label {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 2.5px;
  color: var(--text-muted);
  padding: 16px 20px 6px;
  font-weight: 700;
}

.nav-group-label:first-of-type { padding-top: 6px; }

nav a {
  display: block;
  padding: 8px 20px;
  margin: 0 8px;
  color: var(--text-secondary);
  text-decoration: none;
  font-size: 13.5px;
  border-radius: var(--radius-sm);
  transition: all var(--duration-fast) var(--ease-out);
  position: relative;
}

nav a:hover {
  color: var(--text);
  background: var(--surface-hover);
}

nav a.active {
  color: var(--accent-strong);
  background: var(--accent-glow);
  font-weight: 600;
}

nav a.active::before {
  content: '';
  position: absolute;
  left: -8px;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 16px;
  background: var(--accent);
  border-radius: 2px;
}

.nav-footer {
  margin-top: auto;
  padding: 16px 20px;
  border-top: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
}

.nav-footer a {
  font-size: 12px;
  color: var(--text-muted);
  padding: 4px 8px;
  margin: 0;
}

.nav-footer a:hover { color: var(--text-secondary); background: transparent; }

/* ===================== 主内容区 ===================== */
main {
  margin-left: var(--nav-width);
  padding: 48px 56px;
  max-width: calc(var(--nav-width) + var(--content-max));
  width: 100%;
}

/* ===================== 移动端 ===================== */
.hamburger {
  display: none;
  position: fixed;
  top: 14px;
  right: 14px;
  z-index: 200;
  width: 42px;
  height: 42px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  color: var(--text);
  font-size: 20px;
  cursor: pointer;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast);
  box-shadow: var(--shadow-sm);
}

.hamburger:hover { border-color: var(--accent); }

.nav-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 99;
  backdrop-filter: blur(2px);
}

@media (max-width: 768px) {
  nav {
    position: fixed;
    top: 0; left: 0; bottom: 0;
    width: 280px;
    z-index: 150;
    transform: translateX(-100%);
    transition: transform 0.3s var(--ease-out);
    box-shadow: var(--shadow-md);
  }

  nav.open { transform: translateX(0); }

  main {
    margin-left: 0;
    max-width: 100%;
    padding: 24px 18px;
  }

  .nav-overlay { display: block; }
  .nav-overlay.show { display: block; }
  .nav-overlay:not(.show) { display: none; }

  .hamburger { display: flex; }

  #toc-panel { display: none !important; }

  h2 { font-size: 19px; }
  h3 { font-size: 15px; }
}

@media (min-width: 769px) {
  .hamburger, .nav-overlay { display: none !important; }
}

/* ===================== 打印样式 ===================== */
@media print {
  nav, #toc-panel, #back-to-top, .hamburger, .nav-overlay,
  .search-wrap, #tier-bar, .breadcrumb {
    display: none !important;
  }
  main {
    margin-left: 0;
    padding: 0;
    max-width: 100%;
  }
  body { background: #fff; color: #000; font-size: 12px; }
  .card { border: 1px solid #ddd; break-inside: avoid; }
  .card-title { color: #000; }
  .info, .warn { border-left-width: 2px; }
}