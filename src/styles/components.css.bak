/* ============================================
   道友攻略站 · 组件样式 v3
   ============================================ */

/* 面包屑 */
.breadcrumb {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 28px;
  font-size: 12.5px;
  color: var(--text-muted);
}
.breadcrumb a {
  color: var(--text-secondary);
  text-decoration: none;
  transition: color var(--duration-fast);
}
.breadcrumb a:hover { color: var(--accent); }
.breadcrumb .separator { color: var(--border); font-size: 10px; }
.breadcrumb .current { color: var(--text); font-weight: 600; }

/* 搜索栏 */
.search-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 14px;
}

#search {
  flex: 1;
  padding: 10px 16px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  color: var(--text);
  font-size: 14px;
  outline: none;
  transition: all var(--duration-fast) var(--ease-out);
}
#search:focus {
  border-color: var(--accent);
  box-shadow: 0 0 0 3px var(--accent-glow);
}
#search::placeholder { color: var(--text-muted); }

#search-count {
  font-size: 12px;
  color: var(--text-muted);
  white-space: nowrap;
  min-width: 48px;
  text-align: center;
  display: none;
}
#search-count.visible { display: inline; }

.search-nav-btn {
  width: 32px; height: 32px;
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  cursor: pointer;
  font-size: 12px;
  display: none;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast) var(--ease-out);
}
.search-nav-btn.visible { display: flex; }
.search-nav-btn:hover { border-color: var(--accent); color: var(--accent); }
.search-nav-btn:disabled { opacity: 0.25; cursor: default; border-color: var(--border); color: var(--text-muted); }

mark.search-hit {
  background: var(--accent);
  color: #111;
  padding: 0 2px;
  border-radius: 2px;
}
mark.search-hit.current {
  background: var(--danger);
  color: #fff;
}

/* 品质筛选栏 */
#tier-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 28px;
}

.tier-btn {
  padding: 5px 14px;
  border-radius: 20px;
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--text-secondary);
  font-size: 12.5px;
  cursor: pointer;
  transition: all var(--duration-fast) var(--ease-out);
  font-weight: 600;
  letter-spacing: 0.3px;
}

.tier-btn:hover {
  border-color: var(--accent);
  color: var(--text);
}

.tier-btn.active {
  background: var(--accent);
  color: #111;
  border-color: var(--accent);
  box-shadow: var(--shadow-glow);
}

.tier-btn.reset { border-style: dashed; }

.tier-hidden { display: none !important; }
.hidden { display: none !important; }

/* 内容区 */
section {
  margin-bottom: 48px;
  animation: sectionIn 0.4s var(--ease-out);
}

@keyframes sectionIn {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

h2 {
  font-size: 22px;
  font-weight: 800;
  margin-bottom: 18px;
  padding-bottom: 10px;
  border-bottom: 2px solid var(--border);
  display: flex;
  align-items: center;
  gap: 10px;
  letter-spacing: 0.5px;
}

h2 .icon { font-size: 26px; }

h3 {
  font-size: 16px;
  font-weight: 700;
  margin: 28px 0 12px;
  display: flex;
  align-items: center;
  gap: 8px;
}

p {
  margin: 8px 0;
  color: var(--text-secondary);
  font-size: 14px;
}

/* 品质徽章 */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 3px 10px;
  border-radius: 4px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.5px;
  line-height: 1.5;
}
.badge-xh { background: var(--xh-bg); color: #1a1200; }
.badge-ll { background: var(--ll-bg); color: #fff; }
.badge-jx { background: var(--jx-bg); color: #fff; }
.badge-ct { background: var(--ct-bg); color: #fff; }
.badge-zx { background: var(--zx-bg); color: #fff; }
.badge-qy { background: var(--qy-bg); color: #0a1a20; }
.badge-hc { background: var(--hc-bg); color: #fff; }
.badge-zj { background: linear-gradient(135deg, #8899b4, #556680); color: #fff; }

/* 卡片 */
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 18px 22px;
  margin: 12px 0;
  transition: all var(--duration-fast) var(--ease-out);
  position: relative;
}

.card:hover {
  border-color: var(--border-light);
  box-shadow: var(--shadow-sm);
}

.card-title {
  font-weight: 700;
  font-size: 14px;
  margin-bottom: 8px;
  color: var(--accent-strong);
  letter-spacing: 0.3px;
}

/* 路线列表 */
.route {
  list-style: none;
  padding: 0;
}

.route li {
  padding: 6px 0 6px 22px;
  position: relative;
  font-size: 14px;
}

.route li::before {
  content: "→";
  position: absolute;
  left: 2px;
  color: var(--accent);
  font-weight: 700;
}

.route li.sub {
  padding-left: 34px;
  font-size: 13px;
  color: var(--text-secondary);
}

.route li.sub::before {
  content: "·";
  left: 16px;
  color: var(--text-muted);
}

/* 步骤流程 */
.flow {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 5px;
  font-size: 13.5px;
  margin: 8px 0;
}

.flow .step {
  background: var(--surface-active);
  padding: 5px 12px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
  white-space: nowrap;
  font-weight: 500;
  transition: all var(--duration-fast);
}

.flow .step:hover {
  border-color: var(--accent);
  background: var(--accent-glow);
}

.flow .arrow {
  color: var(--accent);
  font-weight: 700;
  font-size: 12px;
}

/* 提示框 */
.info {
  background: var(--info-bg);
  border-left: 3px solid var(--accent);
  padding: 10px 16px;
  margin: 10px 0;
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-size: 13.5px;
  color: var(--accent-strong);
}

.warn {
  background: var(--danger-bg);
  border-left: 3px solid var(--danger);
  padding: 10px 16px;
  margin: 10px 0;
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  font-size: 13.5px;
  color: #f08080;
}

[data-theme="light"] .warn {
  color: #cc4040;
}

/* 优先级列表 */
.prio {
  list-style: none;
  padding: 0;
  font-size: 14px;
}

.prio li {
  padding: 3px 0;
  color: var(--text-secondary);
}

.prio li b { color: var(--text); }

/* 表格 */
table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13.5px;
  margin: 12px 0;
  border-radius: var(--radius-sm);
  overflow: hidden;
  border: 1px solid var(--border);
}

th, td {
  padding: 10px 14px;
  text-align: left;
  border-bottom: 1px solid var(--border);
}

th {
  color: var(--text-muted);
  font-weight: 700;
  font-size: 11.5px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  background: var(--bg-raised);
}

td { color: var(--text); }
tr:last-child td { border-bottom: none; }
tr:hover td { background: var(--surface-hover); }

/* 浮动目录 (TOC) */
#toc-panel {
  position: fixed;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  width: 180px;
  max-height: 64vh;
  overflow-y: auto;
  background: var(--bg-raised);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 14px 12px;
  z-index: 50;
  font-size: 12px;
  display: none;
  opacity: 0;
  transition: opacity 0.3s var(--ease-out);
  box-shadow: var(--shadow-md);
}

#toc-panel.show { display: block; opacity: 1; }

#toc-panel::-webkit-scrollbar { width: 3px; }
#toc-panel::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }

#toc-panel .toc-title {
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 1.5px;
  color: var(--text-muted);
  margin-bottom: 10px;
  font-weight: 700;
}

#toc-panel a {
  display: block;
  padding: 4px 8px;
  color: var(--text-secondary);
  text-decoration: none;
  border-radius: 4px;
  margin-bottom: 2px;
  transition: all var(--duration-fast);
  border-left: 2px solid transparent;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 11.5px;
}

#toc-panel a:hover,
#toc-panel a.active {
  color: var(--text);
  border-left-color: var(--accent);
  background: var(--surface-hover);
}

/* 折叠展开 */
.collapse-toggle {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  cursor: pointer;
  color: var(--accent);
  font-size: 12px;
  font-weight: 600;
  margin-left: 8px;
  user-select: none;
  padding: 2px 8px;
  border-radius: var(--radius-sm);
  border: 1px solid transparent;
  transition: all var(--duration-fast);
}

.collapse-toggle:hover {
  border-color: var(--accent);
  background: var(--accent-glow);
}

.collapse-toggle .icon-chevron {
  display: inline-block;
  transition: transform 0.25s var(--ease-out);
  font-size: 10px;
}

.collapse-toggle.open .icon-chevron { transform: rotate(90deg); }

.collapse-summary {
  color: var(--text-secondary);
  font-size: 13px;
  cursor: pointer;
  user-select: none;
}

.collapse-body { display: none; }
.collapse-body.open { display: block; }

/* 回到顶部按钮 */
#back-to-top {
  position: fixed;
  bottom: 28px;
  right: 28px;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--text-secondary);
  cursor: pointer;
  font-size: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 60;
  opacity: 0;
  transform: translateY(10px);
  pointer-events: none;
  transition: all 0.3s var(--ease-out);
  box-shadow: var(--shadow-md);
}

#back-to-top.visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto;
}

#back-to-top:hover {
  border-color: var(--accent);
  color: var(--accent);
  transform: translateY(-2px);
  box-shadow: var(--shadow-glow);
}

/* 主题切换按钮 */
.theme-toggle {
  width: 32px;
  height: 32px;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--text-secondary);
  cursor: pointer;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all var(--duration-fast) var(--ease-out);
}
.theme-toggle:hover {
  border-color: var(--accent);
  color: var(--accent);
}

/* 首页特殊样式 */
.hub-hero {
  text-align: center;
  padding: 48px 20px 36px;
  border-bottom: 1px solid var(--border);
  margin-bottom: 36px;
}

.hub-hero h1 {
  font-size: 30px;
  background: linear-gradient(135deg, var(--accent-strong), var(--accent));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  font-weight: 800;
  margin-bottom: 10px;
  letter-spacing: 1px;
}

.hub-hero p {
  color: var(--text-muted);
  font-size: 13.5px;
}

.hub-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
  gap: 12px;
  margin-bottom: 32px;
}

.hub-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 22px 18px;
  text-decoration: none;
  transition: all 0.25s var(--ease-out);
  display: flex;
  flex-direction: column;
  gap: 8px;
  position: relative;
  overflow: hidden;
}

.hub-card::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: var(--radius-md);
  opacity: 0;
  transition: opacity 0.25s var(--ease-out);
  background: linear-gradient(135deg, rgba(232,180,79,0.04), transparent);
  pointer-events: none;
}

.hub-card:hover {
  border-color: var(--accent);
  transform: translateY(-3px);
  box-shadow: 0 8px 30px rgba(0,0,0,0.3);
}

.hub-card:hover::after { opacity: 1; }

.hub-card .icon { font-size: 28px; line-height: 1; }

.hub-card .label {
  color: var(--text);
  font-size: 14px;
  font-weight: 700;
}

.hub-card .desc {
  color: var(--text-secondary);
  font-size: 12px;
  line-height: 1.6;
}

.hub-category { margin-bottom: 28px; }

.hub-category h2 {
  font-size: 14px;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 14px;
  padding-left: 2px;
  border-bottom: none;
  font-weight: 700;
}

.hub-footer {
  text-align: center;
  padding: 30px 0;
  color: var(--text-muted);
  font-size: 11.5px;
  border-top: 1px solid var(--border);
}

@media (max-width: 768px) {
  .hub-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  .hub-hero { padding: 32px 16px 24px; }
  .hub-hero h1 { font-size: 22px; }
  .hub-card { padding: 16px 14px; }
}